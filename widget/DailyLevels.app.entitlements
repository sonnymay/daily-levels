<?xml version="1.0" encoding="UTF-8"?>
<!-- App-side entitlements for v1.1. Add to the MAIN app target's CODE_SIGN_ENTITLEMENTS
     at the same time you add the widget (NOT before — it would gate the freemium archive
     until the App Group is registered in the dev portal). -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.santipapmay.DailyLevels</string>
	</array>
</dict>
</plist>
